# Nole Code Environment Variables
# Copy to .env and fill in your values

# Primary: MiniMax API Key (free tier available)
# Get from: https://platform.minimaxi.com
MINIMAX_API_KEY=your_minimax_api_key_here

# Fallback: OpenRouter API Key (auto-fallback when MiniMax is overloaded)
# Get from: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...

# Fallback: OpenAI API Key
# OPENAI_API_KEY=sk-...

# Optional: Feature flags (comma-separated)
# NOLE_FEATURES=PERMISSION_RULES,AUTO_COMPACT,SESSION_COMPACT

# Optional: Enable debug mode
# DEBUG_TOOL=1
